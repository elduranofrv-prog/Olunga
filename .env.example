# Server
NODE_ENV=development
PORT=3000
# Comma-separated origins permitted to call /pay. Leave unset for same-origin only.
ALLOWED_ORIGINS=

# Daraja Sandbox credentials. Obtain these from https://developer.safaricom.co.ke/
DARAJA_CONSUMER_KEY=your_sandbox_consumer_key
DARAJA_CONSUMER_SECRET=your_sandbox_consumer_secret
DARAJA_BUSINESS_SHORT_CODE=174379
DARAJA_PASSKEY=your_sandbox_lipa_na_mpesa_online_passkey
# A public HTTPS URL Daraja can POST to; do not use localhost in Sandbox.
DARAJA_CALLBACK_URL=https://your-public-domain.up.railway.app/callback
DARAJA_ACCOUNT_REFERENCE=OLUNGA
DARAJA_TRANSACTION_DESC=Payment
# Sandbox endpoints are the defaults. Override only for an approved environment.
DARAJA_OAUTH_URL=https://sandbox.safaricom.co.ke/oauth/v1/generate?grant_type=client_credentials
DARAJA_STK_PUSH_URL=https://sandbox.safaricom.co.ke/mpesa/stkpush/v1/processrequest
